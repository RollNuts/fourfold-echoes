{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "contracts/schemas/forge-event.schema.json",
  "title": "Forge event",
  "type": "object",
  "required": ["event", "commandId", "status"],
  "additionalProperties": false,
  "properties": {
    "event": {
      "type": "string",
      "pattern": "^[a-z0-9_.-]+$"
    },
    "commandId": {
      "type": "string",
      "pattern": "^cmd\\.[a-z0-9_.-]+$"
    },
    "semanticId": {
      "type": "string",
      "pattern": "^[a-z]+\\.[a-z0-9_.-]+$"
    },
    "status": {
      "type": "string",
      "enum": ["ok", "warn", "error"]
    },
    "message": {
      "type": "string"
    },
    "artifacts": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^artifacts/[a-z0-9_./-]+$"
      }
    }
  }
}
