* text=auto

# Repo-authored text and scripts.
*.cs text eol=lf
*.asmdef text eol=lf
*.asmref text eol=lf
*.json text eol=lf
*.yaml text eol=lf
*.yml text eol=lf
*.md text eol=lf
*.txt text eol=lf
*.sh text eol=lf
*.mjs text eol=lf

# Unity serialized assets are YAML when Force Text serialization is enabled.
*.meta text eol=lf merge=unityyamlmerge -whitespace
*.unity text eol=lf merge=unityyamlmerge -whitespace
*.prefab text eol=lf merge=unityyamlmerge -whitespace
*.mat text eol=lf merge=unityyamlmerge -whitespace
*.asset text eol=lf merge=unityyamlmerge -whitespace
*.controller text eol=lf merge=unityyamlmerge -whitespace
*.overrideController text eol=lf merge=unityyamlmerge -whitespace
*.anim text eol=lf merge=unityyamlmerge -whitespace
*.mask text eol=lf merge=unityyamlmerge -whitespace
*.playable text eol=lf merge=unityyamlmerge -whitespace
*.terrainlayer text eol=lf merge=unityyamlmerge -whitespace
*.renderTexture text eol=lf merge=unityyamlmerge -whitespace

# Shader and UI source.
*.shader text eol=lf
*.shadergraph text eol=lf
*.compute text eol=lf
*.hlsl text eol=lf
*.cginc text eol=lf
*.uss text eol=lf
*.uxml text eol=lf

# Commercial binary assets belong in Git LFS when intentionally tracked.
